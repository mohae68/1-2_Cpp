#include <iostream>
using namespace std;

//클래스 선언부
class Triangle {
private:
public:
	int width, height;//멤버 변수
	int getArea();//멤버 함수
	Triangle();//디폴트 생성자
	Triangle(int a, int b);//오버로딩 생성자
};
//구현부
Triangle::Triangle() {
	width = 1;
	height = 1;
	cout << "너비는 " << width << " 높이는 " << height << "이 생성됐다." << endl;
}
Triangle::Triangle(int a, int b) {
	width = a;
	height = b;
	cout<< "너비는 " << width << " 높이는 " << height << "이 생성됐다." << endl;
}
int Triangle::getArea() {
	return width * height / 2;
}

//main()
int main()
{
	Triangle Tri1; //객체 생성
	int area = Tri1.getArea();
	cout << "삼각형A의 면적은 " << area << endl;

	Triangle Tri2(5, 2); //객체2 생성
	area = Tri2.getArea();
	cout << "삼각형B의 면적은 " << area;

	return 0;
	
}

