#include <iostream>
#include <string>
using namespace std;

//2차원 평면에서 한 점을 표현하는 클래스 Point 선언
class Point {
protected:
	int x, y;
public:
	void set(int x, int y) { this->x = x;  this->y = y; }
	void showPoint() {
		cout << "(" << x << "," << y << ")" << endl;
	}
};

class ColorPoint : public Point { //2차원 평면에서 컬러점을 표현하는 클래스 colorpoint. point를 상속 받음
private:
	string color; //점의 색 표현
public:
	void setColor(string color) { this->color = color; }
	void showColorPoint();
};

void ColorPoint::showColorPoint() {
	cout << color << ":";
	showPoint();
}

int main() {
	Point p; //기본 클래스의 객체 생성 (정적 할당)
	ColorPoint cp; //파생 클래스의 객체 생성

	cp.set(3, 4); //기본 클래스의 멤버 호출
	cp.setColor("Red"); //파생 클래스의 멤버 호출
	cp.showColorPoint(); //파생 클래스의 멤버 호출

	//이거 알고 있기!(업캐스팅, 다운캐스팅)
	ColorPoint* pDer = &cp; //이건 업캐스팅이 아님, 동등하기 때문에!
	pDer->showColorPoint(); //포인터로 멤버 함수 호출!
	Point* pBase = &cp; //포인터는 주소만 받을 수 있기 때문에 주소를 담은 것. 업캐스팅 방법 1(교수방법)
	Point* pBase2 = pDer; //업캐스팅 방법 2(교재방법)
	((ColorPoint*)pBase)->showPoint(); //이건 다운캐스팅 하여 showPoint 호출하기!

}
